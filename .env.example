# ============================================================
# AI A-Stock 环境变量配置
# 复制此文件为 .env 并根据需要修改
# ============================================================

# Web 服务器
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# 日志级别 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# AI 多智能体分析 (DeepSeek)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_ANALYST_MODEL=deepseek-v4-pro
AI_MAX_DEBATE_ROUNDS=1
AI_MAX_RISK_ROUNDS=1
